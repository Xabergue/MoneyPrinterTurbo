# ============================================================
# MoneyPrinterTurbo — Configuração
# Copie este arquivo para .env e preencha os valores
# ============================================================

# ── LLM ─────────────────────────────────────────────────────
# URL do seu proxy local (DeepSProxy, Ollama, etc.)
LLM_BASE_URL=http://localhost:3000/v1
# Nome do modelo
LLM_MODEL=deepseek-chat
# Chave de API (qualquer string para endpoints locais)
LLM_API_KEY=local

# ── Fontes de Vídeo ──────────────────────────────────────────
# Fonte padrão: "pexels", "pixabay" ou "local"
VIDEO_SOURCE=pexels
# Chave do Pexels (https://www.pexels.com/api/)
PEXELS_API_KEY=
# Chave do Pixabay (https://pixabay.com/api/docs/)
PIXABAY_API_KEY=

# ── TTS (Kokoro) ─────────────────────────────────────────────
# Voz padrão. Opções disponíveis em docs/voice-list.txt
TTS_VOICE=pf_dora
# Velocidade da fala (0.5 = lento, 1.0 = normal, 2.0 = rápido)
TTS_SPEED=1.0

# ── Legendas (Whisper) ───────────────────────────────────────
# Modelo: tiny, base, small, medium, large-v3
# "medium" recomendado — bom equilíbrio qualidade/velocidade
WHISPER_MODEL=medium
# Dispositivo: "cpu" ou "cuda" (GPU NVIDIA)
WHISPER_DEVICE=cpu
# Tipo de cálculo: "int8" para CPU, "float16" para GPU
WHISPER_COMPUTE_TYPE=int8

# ── Caminhos (Windows) ───────────────────────────────────────
# Caminho do ImageMagick (obrigatório no Windows para legendas)
IMAGEMAGICK_PATH=C:\Program Files\ImageMagick-7.1.2-Q16\magick.exe
# Caminho do FFmpeg (deixe vazio para usar o automático)
FFMPEG_PATH=

# ── Servidor ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=DEBUG
